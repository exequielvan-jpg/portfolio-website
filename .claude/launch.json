{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portfolio",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const dir='/Volumes/Extreme SSD/Claude Code';const types={'.html':'text/html','.js':'text/javascript','.css':'text/css','.svg':'image/svg+xml'};http.createServer((req,res)=>{let u=decodeURIComponent(req.url.split('?')[0]);if(u==='/')u='/index.html';const f=path.join(dir,u);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('not found');}else{res.writeHead(200,{'Content-Type':types[path.extname(f)]||'application/octet-stream'});res.end(d);}});}).listen(4321,()=>console.log('up on 4321'));"],
      "port": 4321
    }
  ]
}
